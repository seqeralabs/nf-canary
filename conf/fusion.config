/*
 * Fusion Validation Profiles
 *
 * These profiles define recommended thresholds for different cloud environments.
 * Each profile enables fusion and points to a requirements YAML file
 * that is passed to `fusion doctor --reference-profile`.
 *
 * Usage: nextflow run seqeralabs/nf-canary -profile fusion_aws_recommended
 */

profiles {

    fusion_aws_recommended {
        params.fusion        = true
        params.fusion_reference_profile = "${projectDir}/assets/fusion-aws-recommended.yaml"
    }

    fusion_google_recommended {
        params.fusion        = true
        params.fusion_reference_profile = "${projectDir}/assets/fusion-google-recommended.yaml"
    }

    fusion_azure_recommended {
        params.fusion        = true
        params.fusion_reference_profile = "${projectDir}/assets/fusion-azure-recommended.yaml"
    }

}
