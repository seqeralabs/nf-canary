params {
    skip                      = ''
    gpu                       = false
    run                       = ''
    outdir                    = null
    remoteFile                = null
    container                 = "quay.io/biocontainers/ubuntu:24.04"
    fusion                    = false
    fusion_kernel_version_min = null
    fusion_memory_gb_min      = null
    fusion_disk_gb_min        = null
    fusion_cache_path         = '/tmp'
    fusion_read_write_buckets = null
    fusion_read_only_buckets  = null
}

process {
    container     = params.container
    errorStrategy = "finish"
}

includeConfig 'conf/fusion.config'
